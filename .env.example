# Copy this file to .env.local and fill in values from your Firebase project
# (Project settings -> General -> Your apps -> SDK setup and configuration).
# These are client-side identifiers, not secrets -- it's normal and expected
# for them to end up in the built JS bundle. Real access control lives in
# firestore.rules, not in hiding these values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Maps Static API key -- used to render the trip route/location map
# images. Requires a Google Cloud project with billing enabled (Maps
# Platform > Maps Static API). Restrict this key by HTTP referrer to your
# GitHub Pages domain (and localhost for local dev) in the Cloud console --
# it's a public client-side identifier, same as the Firebase config above.
VITE_GOOGLE_MAPS_STATIC_KEY=
